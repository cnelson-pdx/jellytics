# Jellytics environment variables
# Copy this to .env and fill in your values

# Jellyfin server (can also be set in config.yaml)
JELLYFIN_URL=http://192.168.3.2:8096
JELLYFIN_API_KEY=your_api_key_here

# Database (defaults to SQLite)
# For PostgreSQL: postgresql+asyncpg://user:pass@host:5432/jellytics
DATABASE_URL=sqlite+aiosqlite:///./data/jellytics.db

# Web interface
JELLYTICS_HOST=0.0.0.0
JELLYTICS_PORT=8234
JELLYTICS_SECRET_KEY=change_me_to_a_random_string

# Config file path
JELLYTICS_CONFIG=./config.yaml
